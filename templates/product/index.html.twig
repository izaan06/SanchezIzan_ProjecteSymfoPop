{% extends 'base.html.twig' %}

{% block title %}Productes - SymfoPop{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ title|default('Catàleg de Productes') }}</h1>
        {% if show_new_button|default(false) %}
            <a href="{{ path('app_product_new') }}" class="btn btn-success">Nova Publicació</a>
        {% endif %}
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="{{ product.image|default('https://picsum.photos/seed/' ~ product.id ~ '/600/400') }}" class="card-img-top" alt="{{ product.title }}" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0 text-truncate" style="max-width: 70%;">{{ product.title }}</h5>
                            <span class="badge bg-success fs-6">{{ product.price|number_format(2, ',', '.') }} €</span>
                        </div>
                        <p class="card-text text-muted small mb-3">
                            {{ product.description|length > 100 ? product.description|slice(0, 100) ~ '...' : product.description }}
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="small">
                                <div class="text-dark"><strong>{{ product.owner.name }}</strong></div>
                                <div class="text-muted">{{ product.createdAt|date('d/m/Y') }}</div>
                            </div>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-outline-primary btn-sm">Veure</a>
                                {% if show_actions|default(false) and app.user == product.owner %}
                                    <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-outline-warning btn-sm">Editar</a>
                                    <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" onsubmit="return confirm('Estàs segur?');" style="display:inline-block">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                        <button class="btn btn-outline-danger btn-sm">Esborrar</button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info py-5 text-center">
                    {{ empty_message|default('No hi ha productes disponibles en aquests moments.') }}
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
